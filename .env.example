# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database
MONGODB_URI=mongodb://localhost:27017/fileserver
MONGODB_URI_TEST=mongodb://localhost:27017/fileserver-test

# JWT Tokens
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRE=7d

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600        # 100 MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,txt,doc,docx,zip

# Storage Quotas
DEFAULT_USER_QUOTA=104857600   # 100 MB
ADMIN_QUOTA=1099511627776     # 1 TB

# Security
BCRYPT_ROUNDS=10
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=900000               # 15 minutes

# HTTPS/SSL
HTTPS_ENABLED=false            # Set to true in production
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# Frontend
CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug                # debug, info, warn, error
LOG_DIR=./logs

# Rate Limiting
RATE_LIMIT_WINDOW=15           # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Backup Configuration
BACKUP_DIR=./backups
BACKUP_SCHEDULE=0 2 * * *      # Daily at 2 AM (cron format)
BACKUP_RETENTION_DAYS=30
